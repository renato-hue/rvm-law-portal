            <div style={{fontFamily:"monospace",fontSize:11,color:"#9ca3af",marginTop:2}}>{cliente?.cnpj}</div>
          </div>
          <button style={{...C.sideSmBtn,color:"#ef4444",borderColor:"#fca5a5"}} onClick={onLogout}>Sair</button>
