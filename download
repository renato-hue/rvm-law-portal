function RelatorioCliente({data,cliente,cliStats,onParcelas,onAddParc}){
  const ps=data.parcelamentos.filter(p=>p.clienteId===cliente.id);
  const s=cliStats(cliente.id);
  const pgfn=ps.filter(p=>p.orgao==="PGFN"), rfb=ps.filter(p=>p.orgao==="RFB");
  const cfData=(()=>{const map={};ps.forEach(p=>p.parcelas.forEach(pr=>{
    if(pr.status==="Paga")return;const k=pr.vencimento.slice(0,7);
    if(!map[k])map[k]={mes:k,label:mLabel(pr.vencimento+"-01"),total:0,vencidas:0,aVencer:0};
    map[k].total+=pr.valor;pr.status==="Vencida"?map[k].vencidas+=pr.valor:map[k].aVencer+=pr.valor;
  }));return Object.values(map).sort((a,b)=>a.mes.localeCompare(b.mes));})();
  return(
    <div>
      <div style={{...C.card,display:"flex",justifyContent:"space-between",alignItems:"center",marginBottom:16}}>
        <div><div style={{fontWeight:800,fontSize:19,color:"#111"}}>{cliente.nome}</div>
          <div style={{fontSize:12,color:"#6b7280",marginTop:2}}>CNPJ: {cliente.cnpj}{cliente.responsavel?` · ${cliente.responsavel}`:""}</div></div>
        <button style={C.primaryBtn} onClick={onAddParc}>+ Parcelamento</button>
      </div>
      <div style={C.grid4}>
        <Stat label="Total Parcelas" val={s.total} accent="#111"/>
        <Stat label="Pagas" val={s.pagas} accent="#16a34a"/>
        <Stat label="Vencidas" val={s.vencidas} accent="#ef4444"/>
        <Stat label="Saldo Devedor" val={fmt(s.saldo)} accent="#111"/>
      </div>
      {cfData.length>0&&<div style={C.card}><div style={C.cardTitle}>Fluxo de Caixa</div><CF data={cfData}/></div>}
      {pgfn.length>0&&<><h3 style={C.secHead}>PGFN</h3>{pgfn.map(p=><ParcCard key={p.id} p={p} onParcelas={()=>onParcelas(p)}/>)}</>}
      {rfb.length>0&&<><h3 style={C.secHead}>Receita Federal — RFB</h3>{rfb.map(p=><ParcCard key={p.id} p={p} onParcelas={()=>onParcelas(p)}/>)}</>}
      {ps.length===0&&<Empty msg="Nenhum parcelamento para este cliente."/>}
    </div>
  );
}

function ParcCard({p,onParcelas}){
  const pagas=p.parcelas.filter(x=>x.status==="Paga").length;
  const venc=p.parcelas.filter(x=>x.status==="Vencida").length;
  const saldo=p.parcelas.filter(x=>x.status!=="Paga").reduce((s,pr)=>s+pr.valor,0);
  const pct=Math.round((pagas/p.numParcelas)*100);
  return(
    <div style={C.pCard}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:12}}>
        <div>
          <span style={{fontWeight:700,fontSize:14,color:"#111"}}>{p.modalidade}</span>
          <OrgTag o={p.orgao} style={{marginLeft:8}}/>
          <span style={{...C.tag,marginLeft:6}}>{p.formaPagamento}</span>
          {p.descontoPercent>0&&<span style={{...C.tag,marginLeft:6,background:"#fef9c3",color:"#854d0e",border:"1px solid #fde047"}}>Desconto {p.descontoPercent}%</span>}
          {p.numNegociacao&&<span style={{...C.tag,marginLeft:6,fontSize:10,color:"#9ca3af"}}>#{p.numNegociacao}</span>}
        </div>
        <button style={C.link} onClick={onParcelas}>Ver parcelas →</button>
      </div>
      <div style={{display:"flex",gap:22,flexWrap:"wrap",marginBottom:14}}>
        {[["Total",p.numParcelas,"#374151"],["Pagas",pagas,"#16a34a"],["Vencidas",venc,venc>0?"#ef4444":"#9ca3af"],["A Vencer",p.numParcelas-pagas-venc,"#374151"],["Parcela",fmt(p.valorParcela),"#111"],["Saldo Dev.",fmt(saldo),"#111"]].map(([l,v,co])=>(
          <div key={l}><div style={{fontWeight:700,fontSize:14,color:co}}>{v}</div><div style={{fontSize:11,color:"#9ca3af",marginTop:2}}>{l}</div></div>
        ))}
        {p.valorConsolidado>0&&<div><div style={{fontWeight:700,fontSize:14,color:"#374151"}}>{fmt(p.valorConsolidado)}</div><div style={{fontSize:11,color:"#9ca3af",marginTop:2}}>Consolidado</div></div>}
        {p.saldoComJuros>0&&<div><div style={{fontWeight:700,fontSize:14,color:"#374151"}}>{fmt(p.saldoComJuros)}</div><div style={{fontSize:11,color:"#9ca3af",marginTop:2}}>Saldo c/ Juros</div></div>}
      </div>
      <div style={{fontSize:11,color:"#9ca3af",marginBottom:4}}>{pct}% pago ({pagas}/{p.numParcelas})</div>
      <div style={{height:4,background:"#e5e7eb",borderRadius:99}}><div style={{height:"100%",background:"#111",borderRadius:99,width:`${pct}%`,transition:"width .4s"}}/></div>
    </div>
  );
}

function CF({data:d}){
  return(
    <ResponsiveContainer width="100%" height={240}>
      <BarChart data={d} margin={{top:4,right:8,left:0,bottom:0}}>
        <CartesianGrid strokeDasharray="3 3" stroke="#f3f4f6" vertical={false}/>
        <XAxis dataKey="label" tick={{fill:"#9ca3af",fontSize:10}} axisLine={false} tickLine={false} interval={Math.max(0,Math.floor(d.length/16)-1)}/>
        <YAxis tick={{fill:"#9ca3af",fontSize:10}} axisLine={false} tickLine={false} tickFormatter={v=>v>=1000?`${(v/1000).toFixed(0)}k`:v}/>
        <Tooltip formatter={(v,n)=>[fmt(v),n]} contentStyle={{background:"#fff",border:"1px solid #e5e7eb",borderRadius:6,fontSize:12}} labelStyle={{color:"#374151",fontWeight:600}}/>
        <Bar dataKey="aVencer" stackId="a" fill="#374151" name="A Vencer" radius={[0,0,0,0]}/>
        <Bar dataKey="vencidas" stackId="a" fill="#ef4444" name="Vencidas" radius={[3,3,0,0]}/>
      </BarChart>
    </ResponsiveContainer>
  );
}

function Page({title,sub,children}){ return <section style={{maxWidth:1100}}><h1 style={C.pageTitle}>{title}</h1>{sub&&<p style={C.pageSub}>{sub}</p>}<div style={{marginTop:24}}>{children}</div></section>; }
function Stat({label,val,accent}){ return <div style={C.statCard}><div style={{fontSize:22,fontWeight:800,color:accent||"#111",letterSpacing:"-.02em"}}>{val}</div><div style={{fontSize:11,color:"#9ca3af",marginTop:4,fontWeight:600,textTransform:"uppercase",letterSpacing:".06em"}}>{label}</div></div>; }
function Tag({s}){ const cfg={Paga:{c:"#16a34a",bg:"#f0fdf4",b:"#bbf7d0"},Vencida:{c:"#ef4444",bg:"#fef2f2",b:"#fecaca"},"A vencer":{c:"#374151",bg:"#f9fafb",b:"#e5e7eb"}}[s]||{c:"#374151",bg:"#f9fafb",b:"#e5e7eb"}; return <span style={{padding:"2px 8px",borderRadius:4,fontSize:11,fontWeight:600,color:cfg.c,background:cfg.bg,border:`1px solid ${cfg.b}`}}>{s}</span>; }
function OrgTag({o}){ return <span style={{...C.tag,background:o==="PGFN"?"#eff6ff":"#f0fdf4",color:o==="PGFN"?"#1d4ed8":"#15803d",border:`1px solid ${o==="PGFN"?"#bfdbfe":"#bbf7d0"}`}}>{o}</span>; }
function Modal({title,onClose,children,wide}){
  return <div style={C.overlay} onClick={e=>e.target===e.currentTarget&&onClose()}>
    <div style={{...C.modal,maxWidth:wide?740:440}}>
      <div style={C.mHead}><span style={{fontWeight:700,fontSize:16,color:"#111"}}>{title}</span><button style={C.xBtn} onClick={onClose}>✕</button></div>
      <div style={C.mBody}>{children}</div>
    </div>
  </div>;
}
function FI({label,v,s,t="text",ph,warn}){ return <div style={{marginBottom:14}}><L>{label}</L><input style={{...C.inp,...(warn?C.warnInp:{})}} type={t} value={v} placeholder={ph||""} onChange={e=>s(e.target.value)}/></div>; }
function L({children}){ return <label style={C.label}>{children}</label>; }
function Empty({msg,action,onClick}){ return <div style={C.empty}><p style={{color:"#9ca3af",marginBottom:12}}>{msg}</p>{action&&<button style={C.primaryBtn} onClick={onClick}>{action}</button>}</div>; }

