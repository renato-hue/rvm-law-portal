/* ─────────────────────────────────────────────
   APP ROOT
───────────────────────────────────────────── */
export default function App() {
  const [auth, setAuth]   = useState(null); // null | {role:"admin"} | {role:"client", clienteId, cnpj}
  const [data, setData]   = useState({clientes:[], parcelamentos:[]});
  const [loading, setLoading] = useState(true);

  // Load persisted data
  useEffect(()=>{
    (async()=>{
      const saved = await store.get("rvm-data");
      if(saved) setData(saved);
      setLoading(false);
    })();
  },[]);

  // Persist on change
  useEffect(()=>{ if(!loading) store.set("rvm-data", data); },[data, loading]);

  const updateData = useCallback(updater => setData(d => { const nd = updater(d); return nd; }), []);

  if(loading) return <Splash />;
  if(!auth) return <LoginPage data={data} onLogin={setAuth} />;
  if(auth.role==="admin") return <AdminApp data={data} updateData={updateData} onLogout={()=>setAuth(null)} />;
  return <ClientApp data={data} auth={auth} onLogout={()=>setAuth(null)} />;
}

