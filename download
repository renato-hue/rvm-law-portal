/* ─────────────────────────────────────────────
   STORAGE (persiste dados entre sessões)
───────────────────────────────────────────── */
const store = {
  async get(k) { try { const r = await window.storage.get(k); return r ? JSON.parse(r.value) : null; } catch { return null; } },
  async set(k, v) { try { await window.storage.set(k, JSON.stringify(v)); } catch(e) { console.error(e); } },
};

/* ─────────────────────────────────────────────
   CONSTANTS
───────────────────────────────────────────── */
const ADMIN_USER = "rvm.adm";
const ADMIN_PASS = "RVM@adm2024";
const PGFN_MOD = ["Simples Nacional","Previdenciário","Não Previdenciário","FGTS","Outros PGFN"];
const RFB_MOD  = ["Parcelamento Comum","PERT","Transação Tributária","Refis","Outros RFB"];
const TODAY = () => new Date().toISOString().split("T")[0];

const fmt    = v => Number(v||0).toLocaleString("pt-BR",{style:"currency",currency:"BRL"});
const fmtDt  = d => { if(!d) return "—"; const[y,m,dy]=d.split("-"); return`${dy}/${m}/${y}`; };
const mLabel = d => { if(!d) return ""; const[y,m]=d.split("-"); return["Jan","Fev","Mar","Abr","Mai","Jun","Jul","Ago","Set","Out","Nov","Dez"][+m-1]+"/"+y.slice(2); };
const cleanCNPJ = s => (s||"").replace(/\D/g,"");

function autoStatus(venc, sitPDF) {
  if (sitPDF === "Paga") return "Paga";
  return venc <= TODAY() ? "Vencida" : "A vencer";
}
function genParcelas(total, start, valor) {
  const list = []; let [y,m,d] = start.split("-").map(Number);
  for (let i=1;i<=total;i++) {
    const dt=`${y}-${String(m).padStart(2,"0")}-${String(d).padStart(2,"0")}`;
    list.push({numero:i,vencimento:dt,valor:Number(valor),situacaoPDF:"A vencer",status:autoStatus(dt,"A vencer")});
    m++; if(m>12){m=1;y++;}
  }
  return list;
}

const EXTRACT_PROMPT = `Você é especialista tributário brasileiro. Extraia dados de parcelamento fiscal deste documento.
Retorne SOMENTE JSON válido (sem markdown) com esta estrutura:
{"cliente":{"nome":null,"cnpj":null},"orgao":null,"modalidade":null,"numNegociacao":null,"programa":null,"situacao":null,"formaPagamento":null,"valorConsolidado":null,"saldoSemJuros":null,"saldoComJuros":null,"semDesconto":null,"descontoPercent":null,"aposDesconto":null,"prestacoes":[{"numero":1,"vencimento":"YYYY-MM-DD","valor":0,"situacaoPDF":"Paga|A vencer|Devedora","saldoDevedor":null}]}
Regras: orgao="PGFN" ou "RFB"; formaPagamento="Boleto" ou "Débito Automático"; situacaoPDF="Paga" se saldo=0 ou palavra paga; datas YYYY-MM-DD; valores numéricos sem formatação; null em campos não encontrados.`;

