/* ─────────────────────────────────────────────
   LOGIN PAGE
───────────────────────────────────────────── */
function LoginPage({ data, onLogin }) {
  const [login, setLogin] = useState("");
  const [pass,  setPass]  = useState("");
  const [error, setError] = useState("");
  const [showPass, setShowPass] = useState(false);

  const handleLogin = () => {
    setError("");
    // Admin
    if(login.trim()===ADMIN_USER && pass===ADMIN_PASS) { onLogin({role:"admin"}); return; }
    // Client: login = CNPJ, pass = senha cadastrada
    const rawLogin = cleanCNPJ(login);
    const cliente = data.clientes.find(c => cleanCNPJ(c.cnpj)===rawLogin && c.senha && c.senha===pass);
    if(cliente) { onLogin({role:"client", clienteId:cliente.id, cnpj:cliente.cnpj, nome:cliente.nome}); return; }
    setError("Credenciais inválidas. Verifique o login e a senha.");
  };

  return (
    <div style={C.loginBg}>
      <div style={C.loginSide}>
        <div style={{flex:1,display:"flex",flexDirection:"column",justifyContent:"center"}}>
          <RVMLogo size="lg" />
          <div style={{marginTop:40}}>
            <div style={C.loginTagline}>Portal de Parcelamentos Fiscais</div>
            <div style={C.loginDesc}>Acesso seguro e centralizado às informações de parcelamentos PGFN e Receita Federal dos seus clientes.</div>
          </div>
        </div>
        <div style={C.loginFooter}>© {new Date().getFullYear()} RVM Law · Todos os direitos reservados</div>
      </div>
      <div style={C.loginForm}>
        <div style={C.loginCard}>
          <div style={C.loginCardTitle}>Acesso ao Portal</div>
          <div style={C.loginCardSub}>Administrador: use seu login RVM<br/>Cliente: use o CNPJ da empresa</div>
          <div style={{marginTop:28,display:"flex",flexDirection:"column",gap:14}}>
            <div>
              <label style={C.label}>Login / CNPJ</label>
              <input style={C.inp} value={login} onChange={e=>setLogin(e.target.value)} placeholder="rvm.adm ou 00.000.000/0001-00" onKeyDown={e=>e.key==="Enter"&&handleLogin()} autoFocus/>
            </div>
            <div>
              <label style={C.label}>Senha</label>
              <div style={{position:"relative"}}>
                <input style={C.inp} type={showPass?"text":"password"} value={pass} onChange={e=>setPass(e.target.value)} placeholder="••••••••" onKeyDown={e=>e.key==="Enter"&&handleLogin()}/>
                <button style={C.eyeBtn} onClick={()=>setShowPass(s=>!s)}>{showPass?"○":"●"}</button>
              </div>
            </div>
            {error && <div style={C.errorBox}>{error}</div>}
            <button style={{...C.primaryBtn,width:"100%",padding:"13px",marginTop:4,fontSize:14}} onClick={handleLogin}>Entrar</button>
          </div>
          <div style={{marginTop:24,paddingTop:20,borderTop:"1px solid #e5e7eb",textAlign:"center",fontSize:12,color:"#9ca3af"}}>
            Dificuldades de acesso? Entre em contato com a RVM Law.
          </div>
        </div>
      </div>
    </div>
  );
}

/* ─────────────────────────────────────────────
   ADMIN APP
───────────────────────────────────────────── */
function AdminApp({ data, updateData, onLogout }) {
  const [view, setView]     = useState("dashboard");
  const [modal, setModal]   = useState(null);
  const [selCli, setSelCli] = useState(null);
  const [selParc, setSelParc] = useState(null);
  const [form, setForm]     = useState({});
  const [toast, setToast]   = useState(null);
  const [cfCli, setCfCli]   = useState("");
  const [cfOrg, setCfOrg]   = useState("Todos");
  const [importStep, setImportStep] = useState("idle");
  const [importing, setImporting]   = useState(false);

  const showToast = (msg,type="ok")=>{ setToast({msg,type}); setTimeout(()=>setToast(null),3000); };
  const sf = k => v => setForm(f=>({...f,[k]:v}));

  // ── DATA OPS ──
  const addCliente = () => {
    if(!form.nome||!form.cnpj) return showToast("Nome e CNPJ obrigatórios","err");
    updateData(d=>({...d,clientes:[...d.clientes,{id:Date.now(),...form}]}));
    setForm({}); setModal(null); showToast("Cliente adicionado!");
  };
  const saveClienteSenha = () => {
    if(!form._editId) return;
    updateData(d=>({...d,clientes:d.clientes.map(c=>c.id===form._editId?{...c,senha:form.senha,responsavel:form.responsavel||c.responsavel}:c)}));
    setModal(null); showToast("Acesso salvo!");
  };
  const addParcelamento = (override={}) => {
    const f={...form,...override};
    if(!f.clienteId||!f.orgao||!f.modalidade||!f.numParcelas||!f.valorParcela||!f.dataInicio)
      return showToast("Preencha campos obrigatórios (*)","err");
    const parcelas = f.prestacoes || genParcelas(Number(f.numParcelas),f.dataInicio,f.valorParcela);
    const novo={id:Date.now(),clienteId:Number(f.clienteId),orgao:f.orgao,modalidade:f.modalidade,
      numNegociacao:f.numNegociacao||"",programa:f.programa||"",numParcelas:Number(f.numParcelas),
      valorParcela:Number(f.valorParcela),formaPagamento:f.formaPagamento||"Boleto",
      situacao:f.situacao||"Ativo",valorConsolidado:Number(f.valorConsolidado||0),
      saldoSemJuros:Number(f.saldoSemJuros||0),saldoComJuros:Number(f.saldoComJuros||0),
      semDesconto:Number(f.semDesconto||0),descontoPercent:Number(f.descontoPercent||0),
      aposDesconto:Number(f.aposDesconto||0),dataInicio:f.dataInicio,parcelas};
    updateData(d=>({...d,parcelamentos:[...d.parcelamentos,novo]}));
    setForm({}); setModal(null); showToast("Parcelamento registrado!");
  };
  const toggleParcela = (pId,num)=>{
    updateData(d=>({...d,parcelamentos:d.parcelamentos.map(p=>{
      if(p.id!==pId) return p;
      return {...p,parcelas:p.parcelas.map(pr=>{
        if(pr.numero!==num) return pr;
        const nx = pr.status==="Paga" ? autoStatus(pr.vencimento,"") : "Paga";
        return {...pr,status:nx};
      })};
    })}));
    setSelParc(p=>p?({...p,parcelas:p.parcelas.map(pr=>{
      if(pr.numero!==num) return pr;
      const nx=pr.status==="Paga"?autoStatus(pr.vencimento,""):"Paga";
      return {...pr,status:nx};
    })}):p);
  };

  // ── AI IMPORT ──
  const handleFile = async e => {
    const file=e.target.files[0]; if(!file) return;
    setImporting(true); setImportStep("reading");
    try {
      let content;
      const ext=file.name.split(".").pop().toLowerCase();
      if(ext==="pdf"){
        const buf=await file.arrayBuffer();
        const b64=btoa(String.fromCharCode(...new Uint8Array(buf)));
        content=[{type:"document",source:{type:"base64",media_type:"application/pdf",data:b64}},{type:"text",text:EXTRACT_PROMPT}];
      } else {
        const XLSX=await import("https://cdn.sheetjs.com/xlsx-0.20.3/package/xlsx.mjs");
        const buf=await file.arrayBuffer();
        const wb=XLSX.read(buf); let txt="";
        wb.SheetNames.forEach(s=>{txt+=`\n--- ${s} ---\n`;txt+=XLSX.utils.sheet_to_csv(wb.Sheets[s]);});
        content=[{type:"text",text:EXTRACT_PROMPT+"\n\nArquivo:\n"+txt}];
      }
      const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:4000,messages:[{role:"user",content}]})});
      const json=await res.json();
      const raw=json.content?.map(b=>b.text||"").join("").trim().replace(/```json|```/g,"").trim();
      const ex=JSON.parse(raw);
      const cMatch=data.clientes.find(c=>cleanCNPJ(c.cnpj)===cleanCNPJ(ex.cliente?.cnpj||""));
      setForm({
        clienteId:cMatch?.id||"",clienteNomeEx:ex.cliente?.nome||"",clienteCNPJEx:ex.cliente?.cnpj||"",
        orgao:ex.orgao||"",modalidade:ex.modalidade||"",numNegociacao:ex.numNegociacao||"",
        programa:ex.programa||"",situacao:ex.situacao||"Ativo",formaPagamento:ex.formaPagamento||"Boleto",
        valorConsolidado:ex.valorConsolidado||"",saldoSemJuros:ex.saldoSemJuros||"",
        saldoComJuros:ex.saldoComJuros||"",semDesconto:ex.semDesconto||"",
        descontoPercent:ex.descontoPercent||"",aposDesconto:ex.aposDesconto||"",
        numParcelas:ex.prestacoes?.length||"",valorParcela:ex.prestacoes?.[0]?.valor||"",
        dataInicio:ex.prestacoes?.[0]?.vencimento||"",
        prestacoes:ex.prestacoes?.map((pr,i)=>({numero:pr.numero||i+1,vencimento:pr.vencimento,valor:pr.valor,
          situacaoPDF:pr.situacaoPDF||"A vencer",status:autoStatus(pr.vencimento,pr.situacaoPDF),saldoDevedor:pr.saldoDevedor||0}))||[],
      });
      setImportStep("reviewing");
    } catch(err){ showToast("Erro: "+err.message,"err"); setImportStep("idle"); }
    finally{ setImporting(false); e.target.value=""; }
  };
  const confirmImport = () => {
    if(!form.clienteId){
      if(!form.clienteNomeEx) return showToast("Selecione ou informe o cliente","err");
      const nc={id:Date.now(),nome:form.clienteNomeEx,cnpj:form.clienteCNPJEx,responsavel:"",senha:""};
      updateData(d=>({...d,clientes:[...d.clientes,nc]}));
      addParcelamento({clienteId:nc.id});
    } else { addParcelamento(); }
    setImportStep("idle");
  };

  // ── STATS ──
  const cliStats = useCallback(cid=>{
    const ps=data.parcelamentos.filter(p=>p.clienteId===cid);
    const all=ps.flatMap(p=>p.parcelas);
    const pagas=all.filter(x=>x.status==="Paga").length;
    const vencidas=all.filter(x=>x.status==="Vencida").length;
    const saldo=all.filter(x=>x.status!=="Paga").reduce((s,pr)=>s+pr.valor,0);
    return{total:all.length,pagas,vencidas,aVencer:all.length-pagas-vencidas,saldo,numParc:ps.length};
  },[data]);

  // ── CASH FLOW ──
  const cashFlow = useMemo(()=>{
    const src=cfCli?data.parcelamentos.filter(p=>p.clienteId===Number(cfCli)):data.parcelamentos;
    const fil=cfOrg==="Todos"?src:src.filter(p=>p.orgao===cfOrg);
    const map={};
    fil.forEach(p=>p.parcelas.forEach(pr=>{
      if(pr.status==="Paga") return;
      const k=pr.vencimento.slice(0,7);
      if(!map[k])map[k]={mes:k,label:mLabel(pr.vencimento+"-01"),total:0,vencidas:0,aVencer:0};
      map[k].total+=pr.valor;
      pr.status==="Vencida"?map[k].vencidas+=pr.valor:map[k].aVencer+=pr.valor;
    }));
    return Object.values(map).sort((a,b)=>a.mes.localeCompare(b.mes));
  },[data,cfCli,cfOrg]);

  const exportJSON=()=>{const b=new Blob([JSON.stringify(data,null,2)],{type:"application/json"});const a=document.createElement("a");a.href=URL.createObjectURL(b);a.download=`rvm-dados-${TODAY()}.json`;a.click();showToast("Exportado!");};
  const importJSON=e=>{const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{try{updateData(()=>JSON.parse(ev.target.result));showToast("Importado!");}catch{showToast("Arquivo inválido","err");}};r.readAsText(f);e.target.value="";};

  const cliObj=data.clientes.find(c=>c.id===selCli);
  const nav=[
    {id:"dashboard",icon:"⬛",label:"Dashboard"},
    {id:"importar",icon:"⚡",label:"Importar IA"},
    {id:"fluxo",icon:"▦",label:"Fluxo de Caixa"},
    {id:"clientes",icon:"◎",label:"Clientes"},
    {id:"parcelamentos",icon:"≡",label:"Parcelamentos"},
    {id:"relatorio",icon:"◧",label:"Relatório"},
    {id:"usuarios",icon:"⬡",label:"Acessos"},
  ];

  return (
    <div style={C.root}>
      <style>{FONTS}</style>
      {/* SIDEBAR */}
      <aside style={C.sidebar}>
        <div style={C.sideTop}>
          <RVMLogo size="sm"/>
          <div style={{marginTop:4,fontSize:10,color:"#9ca3af",letterSpacing:"0.08em",textTransform:"uppercase"}}>Administrador</div>
        </div>
        <nav style={C.nav}>
          {nav.map(n=>(
            <button key={n.id} style={{...C.navBtn,...(view===n.id?C.navActive:{})}} onClick={()=>setView(n.id)}>
              <span style={{fontSize:12,width:16,textAlign:"center",flexShrink:0}}>{n.icon}</span>
              {n.label}
              {n.id==="importar"&&<span style={C.aiTag}>IA</span>}
            </button>
          ))}
        </nav>
        <div style={C.sideBot}>
          <button style={C.sideSmBtn} onClick={exportJSON}>↓ Exportar dados</button>
          <label style={C.sideSmBtn}>↑ Importar dados<input type="file" accept=".json" style={{display:"none"}} onChange={importJSON}/></label>
          <button style={{...C.sideSmBtn,color:"#ef4444",borderColor:"#fca5a5"}} onClick={onLogout}>Sair</button>
        </div>
      </aside>

      {/* MAIN */}
      <main style={C.main}>

        {/* DASHBOARD */}
        {view==="dashboard"&&(
          <Page title="Dashboard" sub="Visão geral consolidada">
            <div style={C.grid4}>
              <Stat label="Clientes" val={data.clientes.length} accent="#111"/>
              <Stat label="Parcelamentos" val={data.parcelamentos.length} accent="#374151"/>
              <Stat label="Parcelas Vencidas" val={data.parcelamentos.flatMap(p=>p.parcelas).filter(x=>x.status==="Vencida").length} accent="#ef4444"/>
              <Stat label="Saldo Devedor Total" val={fmt(data.parcelamentos.flatMap(p=>p.parcelas).filter(x=>x.status!=="Paga").reduce((s,pr)=>s+pr.valor,0))} accent="#111"/>
            </div>
            {cashFlow.length>0&&(
              <div style={C.card}>
                <div style={C.cardTitle}>Fluxo de Caixa — Todos os Clientes</div>
                <CF data={cashFlow.slice(0,18)}/>
              </div>
            )}
            <h3 style={C.secHead}>Alertas — Parcelas Vencidas</h3>
            {data.clientes.filter(c=>cliStats(c.id).vencidas>0).map(c=>{
              const s=cliStats(c.id);
              return(
                <div key={c.id} style={C.alertRow}>
                  <span style={{color:"#ef4444",fontWeight:700}}>⚠</span>
                  <span style={{fontWeight:700,flex:1,color:"#111"}}>{c.nome}</span>
                  <span style={C.tagRed}>{s.vencidas} vencida{s.vencidas>1?"s":""}</span>
                  <span style={{color:"#ef4444",fontWeight:700,fontSize:13}}>{fmt(s.saldo)}</span>
                  <button style={C.link} onClick={()=>{setSelCli(c.id);setView("relatorio");}}>Ver →</button>
                </div>
              );
            })}
            {data.clientes.filter(c=>cliStats(c.id).vencidas>0).length===0&&<p style={{color:"#16a34a",fontSize:13}}>✓ Nenhum alerta no momento.</p>}
          </Page>
        )}

        {/* IMPORTAR */}
        {view==="importar"&&(
          <Page title="Importar com IA" sub="Envie PDF (PGFN/RFB) ou Excel — a IA extrai os dados automaticamente">
            {importStep==="idle"&&(
              <div style={C.uploadBox}>
                <div style={{fontSize:36,marginBottom:12}}>⚡</div>
                <div style={{fontWeight:700,fontSize:17,color:"#111",marginBottom:6}}>Selecione o arquivo</div>
                <div style={{color:"#6b7280",fontSize:13,marginBottom:20}}>PDF da PGFN · PDF da RFB · Excel do portal ou do escritório</div>
                <label style={{...C.primaryBtn,cursor:"pointer",display:"inline-block"}}>
                  {importing?"Lendo com IA...":"Selecionar arquivo"}
                  <input type="file" accept=".pdf,.xlsx,.xls,.csv" style={{display:"none"}} onChange={handleFile} disabled={importing}/>
                </label>
                <div style={{marginTop:14,color:"#9ca3af",fontSize:11}}>A IA extrai: cliente, CNPJ, modalidade, parcelas, valores, descontos e situação.</div>
              </div>
            )}
            {importStep==="reading"&&(
              <div style={{...C.uploadBox}}>
                <div style={{fontSize:28,marginBottom:12,color:"#111"}}>⟳</div>
                <div style={{fontWeight:600,color:"#374151"}}>Analisando arquivo com IA...</div>
              </div>
            )}
            {importStep==="reviewing"&&(
              <div>
                <div style={C.successBox}>✓ Arquivo lido. Revise os dados abaixo antes de salvar — campos em laranja não foram encontrados.</div>
                <div style={C.card}>
                  <div style={C.cardTitle}>Cliente</div>
                  <div style={C.fg2}>
                    <div style={{gridColumn:"1/-1"}}>
                      <L>Vincular a cliente existente</L>
                      <select style={C.inp} value={form.clienteId||""} onChange={e=>sf("clienteId")(e.target.value)}>
                        <option value="">— Criar novo: {form.clienteNomeEx||"?"} —</option>
                        {data.clientes.map(c=><option key={c.id} value={c.id}>{c.nome} — {c.cnpj}</option>)}
                      </select>
                    </div>
                    {!form.clienteId&&<>
                      <FI label="Nome extraído" v={form.clienteNomeEx||""} s={sf("clienteNomeEx")} warn={!form.clienteNomeEx}/>
                      <FI label="CNPJ extraído" v={form.clienteCNPJEx||""} s={sf("clienteCNPJEx")} warn={!form.clienteCNPJEx}/>
                    </>}
                  </div>
                </div>
                <div style={C.card}>
