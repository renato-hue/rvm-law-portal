/* ─────────────────────────────────────────────
   CLIENT APP
───────────────────────────────────────────── */
function ClientApp({ data, auth, onLogout }) {
  const cliente = data.clientes.find(c=>c.id===auth.clienteId);
  const parcelamentos = data.parcelamentos.filter(p=>p.clienteId===auth.clienteId);
  const [view, setView] = useState("visao");
  const [selParc, setSelParc] = useState(null);
  const [modal, setModal] = useState(null);

  const allParcelas = parcelamentos.flatMap(p=>p.parcelas);
  const pagas   = allParcelas.filter(x=>x.status==="Paga").length;
  const vencidas= allParcelas.filter(x=>x.status==="Vencida").length;
  const saldo   = allParcelas.filter(x=>x.status!=="Paga").reduce((s,pr)=>s+pr.valor,0);

  const cashFlow = useMemo(()=>{
    const map={};
    parcelamentos.forEach(p=>p.parcelas.forEach(pr=>{
      if(pr.status==="Paga") return;
      const k=pr.vencimento.slice(0,7);
      if(!map[k])map[k]={mes:k,label:mLabel(pr.vencimento+"-01"),total:0,vencidas:0,aVencer:0};
      map[k].total+=pr.valor;
      pr.status==="Vencida"?map[k].vencidas+=pr.valor:map[k].aVencer+=pr.valor;
    }));
    return Object.values(map).sort((a,b)=>a.mes.localeCompare(b.mes));
  },[parcelamentos]);

  const nav=[{id:"visao",icon:"◈",label:"Visão Geral"},{id:"fluxo",icon:"▦",label:"Fluxo de Caixa"},{id:"parcelamentos",icon:"≡",label:"Parcelamentos"}];

  return (
    <div style={C.root}>
      <style>{FONTS}</style>
      <aside style={C.sidebar}>
        <div style={C.sideTop}>
          <RVMLogo size="sm"/>
          <div style={{marginTop:6,fontSize:10,color:"#9ca3af",letterSpacing:"0.06em",textTransform:"uppercase"}}>Portal do Cliente</div>
        </div>
        <nav style={C.nav}>
          {nav.map(n=>(
            <button key={n.id} style={{...C.navBtn,...(view===n.id?C.navActive:{})}} onClick={()=>setView(n.id)}>
