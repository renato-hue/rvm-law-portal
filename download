      </aside>
      <main style={C.main}>
        {view==="visao"&&(
          <Page title={cliente?.nome||"Minha Conta"} sub={`CNPJ: ${cliente?.cnpj} · ${parcelamentos.length} parcelamento${parcelamentos.length!==1?"s":""}`}>
            <div style={C.grid4}>
              <Stat label="Total Parcelas" val={allParcelas.length} accent="#111"/>
              <Stat label="Pagas" val={pagas} accent="#16a34a"/>
              <Stat label="Vencidas" val={vencidas} accent="#ef4444"/>
              <Stat label="Saldo Devedor" val={fmt(saldo)} accent="#111"/>
