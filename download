              <Stat label="Total Pendente" val={fmt(cashFlow.reduce((s,m)=>s+m.total,0))} accent="#111"/>
              <Stat label="Vencidas" val={fmt(cashFlow.reduce((s,m)=>s+m.vencidas,0))} accent="#ef4444"/>
              <Stat label="Meses com vencimento" val={cashFlow.length} accent="#374151"/>
              <Stat label="Média mensal" val={fmt(cashFlow.length?cashFlow.reduce((s,m)=>s+m.total,0)/cashFlow.length:0)} accent="#111"/>
            </div>
            {cashFlow.length===0?<Empty msg="Nenhum vencimento pendente."/>:<>
              <div style={C.card}><div style={C.cardTitle}>Vencimentos por mês</div><CF data={cashFlow}/></div>
              <div style={C.card}>
                <div style={C.cardTitle}>Tabela detalhada</div>
                <div style={{overflowX:"auto"}}>
                  <table style={C.tbl}>
                    <thead><tr>{["Mês","A Vencer","Vencidas","Total","Acumulado"].map(h=><th key={h} style={C.th}>{h}</th>)}</tr></thead>
                    <tbody>{(()=>{let acc=0;return cashFlow.map((m,i)=>{acc+=m.total;return(
                      <tr key={i} style={{background:m.vencidas>0?"#fef2f2":"transparent"}}>
                        <td style={{...C.td,fontWeight:600,color:"#111"}}>{m.label}</td>
                        <td style={C.td}>{fmt(m.aVencer)}</td>
                        <td style={{...C.td,color:m.vencidas>0?"#ef4444":"#9ca3af"}}>{fmt(m.vencidas)}</td>
                        <td style={{...C.td,fontWeight:700,color:"#111"}}>{fmt(m.total)}</td>
                        <td style={{...C.td,color:"#9ca3af",fontSize:12}}>{fmt(acc)}</td>
                      </tr>
                    );});})()}</tbody>
                  </table>
                </div>
              </div>
            </>}
          </Page>
        )}
        {view==="parcelamentos"&&(
          <Page title="Parcelamentos" sub={`${parcelamentos.length} negociação${parcelamentos.length!==1?"ões":""} ativa${parcelamentos.length!==1?"s":""}`}>
            {parcelamentos.length===0?<Empty msg="Nenhum parcelamento. Entre em contato com a RVM Law."/>:
              parcelamentos.map(p=><ParcCard key={p.id} p={p} onParcelas={()=>{setSelParc(p);setModal("parcelas");}}/>)}
          </Page>
        )}
        {modal==="parcelas"&&selParc&&(
          <Modal title={`Parcelas — ${selParc.modalidade}`} onClose={()=>setModal(null)} wide>
            <div style={{display:"flex",gap:20,marginBottom:14,fontSize:13,flexWrap:"wrap"}}>
              <span>Total: <b>{selParc.numParcelas}</b></span>
              <span style={{color:"#16a34a"}}>Pagas: <b>{selParc.parcelas.filter(x=>x.status==="Paga").length}</b></span>
              <span style={{color:"#ef4444"}}>Vencidas: <b>{selParc.parcelas.filter(x=>x.status==="Vencida").length}</b></span>
              <span style={{color:"#111",fontWeight:700}}>Saldo: <b>{fmt(selParc.parcelas.filter(x=>x.status!=="Paga").reduce((s,p)=>s+p.valor,0))}</b></span>
            </div>
            <div style={{maxHeight:420,overflowY:"auto"}}>
              <table style={C.tbl}>
                <thead><tr>{["Nº","Vencimento","Valor","Status"].map(h=><th key={h} style={C.th}>{h}</th>)}</tr></thead>
                <tbody>{selParc.parcelas.map(pr=>(
                  <tr key={pr.numero} style={C.tr}>
                    <td style={C.td}>{pr.numero}</td>
                    <td style={C.td}>{fmtDt(pr.vencimento)}</td>
                    <td style={{...C.td,fontWeight:600,color:"#111"}}>{fmt(pr.valor)}</td>
                    <td style={C.td}><Tag s={pr.status}/></td>
